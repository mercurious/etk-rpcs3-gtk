+// =========================================================================
+// ETK GTK-Edition audio telemetry (aud1) — counters only, ZERO behavior
+// change. Backend underruns are otherwise silent zero/last-sample fill with
+// no log line at any level, so audible stutter leaves no forensic trace.
+// One raw text line is exported to /dev/shm/rpcs3_audio_stat every ~2 s for
+// the ETK ledger/HUD (atomic tmp+rename, ETK HUD law). Counters reset at
+// cellAudio thread start: a DRM-spawn title's second guest boot re-zeroes,
+// so end-of-session values describe the game proper, not the launcher.
+// =========================================================================
+struct etk_audio_stats_t
+{
+	atomic_t<u64> underrun_events{0}; // backend pulled more than the ring held (cubeb thread)
+	atomic_t<u64> underrun_bytes{0};  // total shortfall bytes (silence-filled downstream)
+	u64 skipped_periods = 0;          // cellAudio advanced past untouched buffers (game fell behind)
+	u64 silence_periods = 0;          // fully-untouched periods enqueued as silence
+	f32 ratio_min = 1.0f;             // lowest time-stretch frequency ratio since start
+	u64 start_us = 0;                 // emu clock at reset
+};
+static etk_audio_stats_t s_etk_aud{};
+
+static void etk_audio_stats_dump(u64 timestamp_us, f32 cur_ratio, u64 enqueued_playtime_us, u32 buf_ms)
+{
+#ifdef __linux__
+	char line[256];
+	const int n = std::snprintf(line, sizeof(line),
+		"up_s=%.1f ur=%llu urb=%llu skip=%llu sil=%llu ratio=%.3f rmin=%.3f enq_ms=%.1f buf_ms=%u\n",
+		(timestamp_us - s_etk_aud.start_us) / 1'000'000.0,
+		static_cast<unsigned long long>(s_etk_aud.underrun_events.load()),
+		static_cast<unsigned long long>(s_etk_aud.underrun_bytes.load()),
+		static_cast<unsigned long long>(s_etk_aud.skipped_periods),
+		static_cast<unsigned long long>(s_etk_aud.silence_periods),
+		cur_ratio, s_etk_aud.ratio_min,
+		enqueued_playtime_us / 1000.0, buf_ms);
+	if (n <= 0) return;
+
+	// Snapshot: latest values, atomically swapped (ETK ledger reads this at post-mortem)
+	if (std::FILE* f = std::fopen("/dev/shm/rpcs3_audio_stat.tmp", "w"))
+	{
+		std::fwrite(line, 1, static_cast<usz>(n), f);
+		std::fclose(f);
+		std::rename("/dev/shm/rpcs3_audio_stat.tmp", "/dev/shm/rpcs3_audio_stat");
+	}
+
+	// aud2: wall-clock-stamped timeline append — one line per dump, so a mixed
+	// session (TT -> ghost -> pack race) decomposes into phases post-hoc and
+	// correlates with the MangoHud fps autolog by epoch. Truncated at counter
+	// reset (fresh per guest boot); size-capped so an hours-long session can
+	// never balloon SHM (~150 KB/h at the 2 s cadence, 2 MB cap ≈ 13 h).
+	if (std::FILE* tl = std::fopen("/dev/shm/rpcs3_audio_log", "a"))
+	{
+		std::fseek(tl, 0, SEEK_END);
+		if (std::ftell(tl) < 2 * 1024 * 1024)
+		{
+			std::fprintf(tl, "ep=%llu %s", static_cast<unsigned long long>(std::time(nullptr)), line);
+		}
+		std::fclose(tl);
+	}
+#endif
+}
