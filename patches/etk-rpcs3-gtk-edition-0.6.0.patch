 	{
 		u32 remap_ctl = registers[NV4097_SET_TEXTURE_CONTROL1 + (m_index * 8)];
+
+		// ETK GTK experiment (11912 road-flicker, dossier Tier0_11912_ShadowRemapLocalization_20260702):
+		// GT5P parks its shadow-map TIU on a 1x1 fallback with a fully zeroed CONTROL1 (= FORCE-ZERO x4
+		// per the GCM enum) -> every track draw samples a constant-0 shadow-visibility term and the
+		// whole track renders shadowed; real hardware evidently treats the parked state as neutral.
+		// v2 (2026-07-02, after on-rig A/B): scoped to the exact confirmed signature — fully zeroed
+		// low word AND a 1x1 texture (on-rig probe showed the 1x1 is the ONLY zero-remap texture in
+		// live GT5P). Two runtime-gated decodes to discriminate what console "neutral" means:
+		//   GTK_REMAP0_ONE=1      -> ONE x4 (content-independent "no shadow"; kills content-staleness
+		//                            blips if the 1x1's texel is meaningless on console)
+		//   GTK_REMAP0_IDENTITY=1 -> identity crossbar (samples the 1x1's live content; correct if the
+		//                            game legitimately animates it as a global dimmer, e.g. tunnels)
+		// ONE wins when both are set. v1's blanket zero-control-field override caused short new
+		// flicker blips (track-dependent) and is retired.
+		static const bool g_gtk_remap0_one = []() { const char* e = std::getenv("GTK_REMAP0_ONE"); return e && *e == '1'; }();
+		static const bool g_gtk_remap0_identity = []() { const char* e = std::getenv("GTK_REMAP0_IDENTITY"); return e && *e == '1'; }();
+		if ((g_gtk_remap0_one || g_gtk_remap0_identity) && (remap_ctl & 0xFFFF) == 0
+			&& width() <= 1 && height() <= 1) [[unlikely]]
+		{
+			static atomic_t<bool> s_logged = false;
+			if (!s_logged.exchange(true))
+			{
+				rsx_log.warning("GTK-REMAP0: %s override engaged (TIU%u raw=0x%08x)",
+					g_gtk_remap0_one ? "force-ONE" : "identity", m_index, remap_ctl);
+			}
+			remap_ctl = (remap_ctl & 0xFFFF0000u) | (g_gtk_remap0_one ? 0x55E4u : 0xAAE4u);
+		}
+
 		u32 remap_override = (remap_ctl >> 16) & 0xFFFF;
 
 		switch (format() & ~(CELL_GCM_TEXTURE_LN | CELL_GCM_TEXTURE_UN))
