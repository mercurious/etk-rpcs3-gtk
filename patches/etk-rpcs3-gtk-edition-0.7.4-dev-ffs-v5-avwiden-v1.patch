+
+// ETK avwiden-v1 (2026-07-12, GTK Edition v0.7.4). Evidence: GT HD at
+// LOCKED-60 burns 13.3 / 20.5 / 14.8% of ALL process cycles (three bog
+// samples, 2026-07-12) inside this handler — one PPU thread streaming
+// writes through texture-cache-protected pages, faulting page by page,
+// every frame. Mitigation: on a WRITE fault, additionally invalidate a
+// readahead span AHEAD of the faulting page so a linear writer takes one
+// fault per span instead of one per 4K page. Correctness: invalidation is
+// conservative by construction (worst case = extra texture revalidation);
+// the faulting page itself KEEPS the stock single-address call, preserving
+// exact violation_handled semantics (a widened-range hit on a neighbor
+// must never report the fault page as handled — that would refault
+// forever). Read faults stay precise (widening a read fault could flush
+// render targets wholesale). Default ON at 65536 (16 pages);
+// GTK_AV_READAHEAD=0 kill-switch, or a byte count (4K..16M, page-rounded).
+namespace
+{
+	u32 etk_av_readahead_bytes()
+	{
+		static const u32 bytes = []() -> u32
+		{
+			if (const char* v = std::getenv("GTK_AV_READAHEAD"))
+			{
+				const u64 parsed = std::strtoull(v, nullptr, 10);
+				if (parsed == 0) return 0;
+				if (parsed >= 4096 && parsed <= 16u * 1024 * 1024) return static_cast<u32>(parsed & ~0xfffull);
+			}
+			return 65536;
+		}();
+		return bytes;
+	}
+}
