-		etk_queue_rescue_notice("GTK RESCUE: CRASH ABSORBED - DRIVE ON", 5'000'000);
+		etk_queue_rescue_notice("GTK Crash Recovery", 5'000'000);
 		return true;
 	}
 
@@ -677,7 +677,7 @@
 			// care which layer caught it.
 			if (etk_steady_now_us() - since >= ETK_STALL_WARN_US)
 			{
-				etk_queue_rescue_notice("GTK RESCUE: CRASH ABSORBED - DRIVE ON", 5'000'000);
+				etk_queue_rescue_notice("GTK Crash Recovery", 5'000'000);
 			}
 			pfence->etk_stale_since_us.release(0);
 			pfence->etk_stale_warned.release(false);
